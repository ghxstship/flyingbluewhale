# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Anthropic AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@flytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── App URL + routing ─────────────────────────────────────────────────────────
# Apex base URL. Use http://lvh.me:3000 with NEXT_PUBLIC_USE_SUBDOMAINS=1 for
# local subdomain routing (atlvs.lvh.me:3000, gvteway.lvh.me:3000, etc.).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "1" to enable subdomain routing in dev (requires lvh.me).
# Leave unset on Vercel preview deploys — falls back to path-prefix mode.
NEXT_PUBLIC_USE_SUBDOMAINS=

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of Origins allowed to send credentialed API requests.
# NEXT_PUBLIC_APP_URL is always included automatically.
ALLOWED_ORIGINS=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=FLYTEHAUS Technologies <no-reply@flytehaus.live>

# ─── Sentry error tracking ─────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Feature flags (GrowthBook) ───────────────────────────────────────────────
GROWTHBOOK_API_HOST=
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=

# ─── Public-link share tokens ─────────────────────────────────────────────────
# HMAC secret for /share/[token] URLs. Rotating invalidates all outstanding links.
# Generate with: openssl rand -base64 32
SHARE_LINK_SECRET=

# ─── Guide access codes ───────────────────────────────────────────────────────
# HMAC secret for signed guide-access cookies. Rotating revokes all live tokens.
# In dev a deterministic fallback is used automatically when this is unset.
GUIDE_ACCESS_SECRET=

# ─── Slack integration ────────────────────────────────────────────────────────
# From https://api.slack.com/apps — OAuth & Permissions tab.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ─── Internal automation worker ───────────────────────────────────────────────
# Bearer token used by the job worker to call /api/v1/internal/automations/*.
# Generate with: openssl rand -hex 32
JOB_WORKER_TOKEN=

# ─── Cloudflare Turnstile (bot protection on public forms) ────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Feature toggles ──────────────────────────────────────────────────────────
# Set to "1" to disable the external weather provider (e.g. while rate-limited).
WEATHER_DISABLED=
# Log level: trace | debug | info | warn | error. Defaults to info.
LOG_LEVEL=
