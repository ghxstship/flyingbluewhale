NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@flytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" to enable subdomain routing (atlvs/gvteway/compvss.flytehaus.live).
# Use "lvh.me" as NEXT_PUBLIC_APP_URL with this flag for local subdomain dev.
# Leave unset on Vercel preview deploys (falls back to path-prefix mode).
NEXT_PUBLIC_USE_SUBDOMAINS=

# HMAC secret for share_links tokens. Generate with: openssl rand -base64 32
# Rotating this invalidates every outstanding /share/[token] URL.
SHARE_LINK_SECRET=
