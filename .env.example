NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@lytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "1" in prod and with lvh.me in dev to enable subdomain routing
NEXT_PUBLIC_USE_SUBDOMAINS=

# Comma-separated list of allowed CORS origins (e.g. https://lytehaus.live)
ALLOWED_ORIGINS=

# HMAC secret for share_links tokens. Generate with: openssl rand -base64 32
# Rotating this invalidates every outstanding /share/[token] URL.
SHARE_LINK_SECRET=

# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Transactional email (Resend)
RESEND_API_KEY=
RESEND_FROM=noreply@lytehaus.live

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GrowthBook feature flags
GROWTHBOOK_API_HOST=https://cdn.growthbook.io
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=
