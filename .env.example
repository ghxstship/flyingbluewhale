NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@lytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# HMAC secret for share_links tokens. Generate with: openssl rand -base64 32
# Rotating this invalidates every outstanding /share/[token] URL.
SHARE_LINK_SECRET=

# Public base URL. Use http://lvh.me:3000 for local subdomain dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" to enable subdomain routing (atlvs.*, gvteway.*, compvss.*).
# Leave unset on Vercel preview deploys — falls back to path-prefix mode.
NEXT_PUBLIC_USE_SUBDOMAINS=

# Comma-separated list of additional allowed CORS origins for /api/v1.
# NEXT_PUBLIC_APP_URL is always included automatically.
ALLOWED_ORIGINS=

# Sentry error tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Slack integration (install via /console/settings/integrations)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Internal job worker authentication token (used by Supabase Edge Function / cron)
# Generate with: openssl rand -hex 32
JOB_WORKER_TOKEN=

# Cloudflare Turnstile bot protection (public forms)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Transactional email (Resend)
RESEND_API_KEY=
RESEND_FROM=LYTEHAUS Technologies <noreply@lytehaus.live>

# Rate-limit store (Upstash Redis). Leave unset to fall back to in-process sliding window.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Feature flags (GrowthBook). Leave unset to use hardcoded defaults.
GROWTHBOOK_API_HOST=
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=

# Set to "1" to disable the external weather provider (e.g. when rate-limiting).
WEATHER_DISABLED=

# Log verbosity floor: trace | debug | info | warn | error. Defaults to info.
LOG_LEVEL=info
