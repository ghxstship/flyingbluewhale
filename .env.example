NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

# Speech-to-text for COMPVSS field dictation (T1-3). Whisper-compatible HTTP
# endpoint; leave OPENAI_API_KEY unset to keep the dictation button hidden.
# TRANSCRIBE_API_URL / TRANSCRIBE_MODEL re-point the same contract at any
# OpenAI-audio-compatible provider (default api.openai.com + whisper-1).
OPENAI_API_KEY=
TRANSCRIBE_API_URL=
TRANSCRIBE_MODEL=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@atlvs.pro
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# HMAC secret for share_links tokens. Generate with: openssl rand -base64 32
# Rotating this invalidates every outstanding /share/[token] URL.
SHARE_LINK_SECRET=

# Sentry error tracking + source-map upload.
# DSN is the public client key (Settings -> Projects -> [project] -> Client Keys).
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload at build (set in CI/Vercel). Org/project slugs +
# an org auth token with CI scope (Settings -> Auth Tokens). When absent
# the build still succeeds (upload skipped).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
