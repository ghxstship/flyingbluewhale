NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@lytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" in prod and in local dev with lvh.me to enable subdomain routing.
# Leave unset on Vercel preview deploys (falls back to path-prefix mode).
# See CLAUDE.md §Environment — Local dev with subdomains.
NEXT_PUBLIC_USE_SUBDOMAINS=

# Comma-separated list of allowed CORS origins for /api/v1.
# NEXT_PUBLIC_APP_URL is always included automatically; add subdomain origins
# for multi-shell browser clients (atlvs., gvteway., compvss.).
# Example: https://atlvs.lytehaus.live,https://gvteway.lytehaus.live,https://compvss.lytehaus.live
ALLOWED_ORIGINS=

# HMAC secret for share_links tokens. Generate with: openssl rand -base64 32
# Rotating this invalidates every outstanding /share/[token] URL.
SHARE_LINK_SECRET=

# Sentry — error monitoring.
# Get DSN from https://sentry.io → Project → Settings → Client Keys.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload token (CI only — do not commit real values).
SENTRY_AUTH_TOKEN=
