# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Anthropic AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@lytehaus.live

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@lytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Share-link tokens ───────────────────────────────────────────────────────
# HMAC secret for /share/[token] URLs. Generate with: openssl rand -base64 32
# Rotating this value invalidates every outstanding share link.
SHARE_LINK_SECRET=

# ─── Internal job worker ─────────────────────────────────────────────────────
# Bearer token verified by /api/v1/internal/automations/dispatch and /schedule.
# Must match the token set in the Supabase job-worker Edge Function config.
# Generate with: openssl rand -base64 32
JOB_WORKER_TOKEN=

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Optional — in-memory fallback used if not set (suitable for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Feature flags (GrowthBook) ──────────────────────────────────────────────
GROWTHBOOK_API_HOST=https://cdn.growthbook.io
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=

# ─── Observability (Sentry) ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Multi-tenant routing ─────────────────────────────────────────────────────
# Base URL of the deployment. Used for sitemaps, OG cards, and subdomain derivation.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "1" to enable subdomain routing (atlvs.*, gvteway.*, compvss.*).
# Use lvh.me in local dev (e.g. http://lvh.me:3000). Leave unset on Vercel
# preview deploys to fall back to path-prefix mode (/console, /p, /m).
NEXT_PUBLIC_USE_SUBDOMAINS=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for credentialed cross-origin
# /api/v1 requests. NEXT_PUBLIC_APP_URL is always included automatically.
ALLOWED_ORIGINS=

# ─── Misc ────────────────────────────────────────────────────────────────────
# Set to "1" to disable the external weather provider (e.g. when rate-limited).
WEATHER_DISABLED=
# Logger floor: trace | debug | info | warn | error  (default: info)
LOG_LEVEL=info
