NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ops@flytehaus.live
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" in prod and dev (with lvh.me) to enable subdomain routing.
# Leave unset on Vercel preview deploys (falls back to path-prefix mode).
NEXT_PUBLIC_USE_SUBDOMAINS=

# Comma-separated list of origins allowed to send credentialed cross-origin
# requests to /api/v1 (e.g. https://flytehaus.live,https://atlvs.flytehaus.live).
# NEXT_PUBLIC_APP_URL is automatically appended.
ALLOWED_ORIGINS=

# Sentry DSN — errors and traces. Leave unset to disable Sentry.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# HMAC secret for share_links tokens. Generate with: openssl rand -base64 32
# Rotating this invalidates every outstanding /share/[token] URL.
SHARE_LINK_SECRET=
