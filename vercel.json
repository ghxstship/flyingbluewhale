{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build",
  "framework": "nextjs",
  "crons": [],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "(www\\.)?lytehaus\\.(app|tech|pro|com)" }],
      "destination": "https://lytehaus.live/:path*",
      "permanent": true
    }
  ]
}
